    "babel-plugin-react-compiler": "1.0.0",
    "commitizen": "^4.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.3.0-canary.45",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "inquirer": "^12.11.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
